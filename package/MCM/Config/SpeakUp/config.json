{
    "modName": "SpeakUp",
    "displayName": "Speak Up",
    "minMcmVersion": 1,
    "pages": [
        {
            "pageDisplayName": "General",
            "content": [
                { "text": "Casting & Equipping", "type": "header" },
                {
                    "id": "iDefaultAction:Voice",
                    "text": "Default action",
                    "type": "enum",
                    "help": "What happens when you say a spell/power/shout name with no prefix. Equip: equips it to your hand. Cast: fires it instantly. The 'cast'/'equip' prefixes always override.",
                    "valueOptions": { "sourceType": "ModSettingInt", "options": ["Equip", "Cast"], "defaultValue": 1 }
                },
                {
                    "id": "iEquipDefaultHand:Voice",
                    "text": "Default equip hand",
                    "type": "enum",
                    "help": "Hand used by 'equip <spell>' (and a bare name when Default action is Equip). 'equip left/right/dual' always override.",
                    "valueOptions": { "sourceType": "ModSettingInt", "options": ["Left", "Right", "Both"], "defaultValue": 0 }
                },
                { "text": "Instant Casting", "type": "header" },
                {
                    "id": "bInstantCast:Voice",
                    "text": "Instant-cast spells",
                    "type": "toggle",
                    "help": "ON: 'cast <spell>' fires the spell instantly (costs magicka). OFF: it equips the spell so you cast it yourself.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": true }
                },
                {
                    "id": "bAllowConcentration:Voice",
                    "text": "Allow instant concentration spells",
                    "type": "toggle",
                    "help": "Concentration spells (e.g. Flames) misbehave when instant-cast, so by default they are equipped instead. Turn ON to instant-cast them anyway.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                },
                {
                    "id": "bAllowLongCast:Voice",
                    "text": "Allow instant long-charge spells",
                    "type": "toggle",
                    "help": "Long-charge spells (e.g. Mass Paralysis) are equipped instead of instant-cast by default. Turn ON to instant-cast them anyway.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                },
                {
                    "id": "fLongCastThreshold:Voice",
                    "text": "Long-charge threshold",
                    "type": "slider",
                    "help": "Charge time (seconds) at/above which a spell counts as 'long'.",
                    "valueOptions": { "sourceType": "ModSettingFloat", "min": 0.0, "max": 5.0, "step": 0.1, "defaultValue": 1.0, "formatString": "{2} s" }
                }
            ]
        },
        {
            "pageDisplayName": "Voice",
            "content": [
                { "text": "Recognition", "type": "header" },
                {
                    "id": "fSensitivity:Voice",
                    "text": "Sensitivity",
                    "type": "slider",
                    "help": "Minimum confidence to accept a recognized phrase. 0 = accept anything (most responsive). Raise toward ~0.5 if background noise triggers false casts. (Vosk engine only.)",
                    "valueOptions": { "sourceType": "ModSettingFloat", "min": 0.0, "max": 1.0, "step": 0.05, "defaultValue": 0.0, "formatString": "{2}" }
                },
                {
                    "id": "fUtteranceThreshold:Voice",
                    "text": "Response speed (utterance threshold)",
                    "type": "slider",
                    "help": "Seconds the recognizer waits after your best guess stops changing before it fires. LOWER = faster; too low can cut off multi-word phrases. (Vosk engine only.)",
                    "valueOptions": { "sourceType": "ModSettingFloat", "min": 0.1, "max": 2.0, "step": 0.1, "defaultValue": 1.0, "formatString": "{1} s" }
                },
                { "text": "Listen Controls (optional)", "type": "header" },
                {
                    "id": "bEnablePushToTalk:Voice",
                    "text": "Enable push-to-talk",
                    "type": "toggle",
                    "help": "ON: HOLD the push-to-talk key to listen, release to send. OFF (default): always listening unless muted with the toggle key. Bind the key in SKSE/Plugins/SpeakUp.ini (PushToTalkKeyDX).",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                },
                {
                    "id": "bEnableListenToggle:Voice",
                    "text": "Enable listen toggle",
                    "type": "toggle",
                    "help": "ON: PRESS the toggle key to switch hands-free listening on/off. Bind the key in SKSE/Plugins/SpeakUp.ini (ListenToggleKeyDX).",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                }
            ]
        },
        {
            "pageDisplayName": "Advanced",
            "content": [
                { "text": "Shouts", "type": "header" },
                {
                    "id": "bShoutUseRealCast:Voice",
                    "text": "Full shout pipeline",
                    "type": "toggle",
                    "help": "ON (default): script/movement shouts (Whirlwind Sprint, Become Ethereal) use the real shout pipeline so their movement/scripts fire; normal shouts stay instant. OFF: force fast instant-cast for ALL shouts (use if the full pipeline misbehaves in fullscreen-exclusive).",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": true }
                },
                {
                    "id": "bPlayShoutAnimation:Voice",
                    "text": "Play shout animation",
                    "type": "toggle",
                    "help": "EXPERIMENTAL. Plays the visible shout body animation on the instant-cast path. OFF by default.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                },
                { "text": "Large Spell Lists", "type": "header" },
                {
                    "id": "bScopeAtScale:Voice",
                    "text": "Limit huge spell lists to favorites",
                    "type": "toggle",
                    "help": "OFF (default): all known spells are voice-castable. ON: when you know 600+ spells, limit the vocabulary to FAVORITED + equipped spells (plus all powers/shouts) for speed/accuracy.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                }
            ]
        },
        {
            "pageDisplayName": "Developer",
            "content": [
                { "text": "Diagnostics", "type": "header" },
                {
                    "id": "bDebugLogging:Voice",
                    "text": "Debug logging",
                    "type": "toggle",
                    "help": "ON: logs every recognized phrase + diagnostics to SpeakUp.log (useful for bug reports). OFF: only warnings/errors.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": true }
                },
                {
                    "id": "bDumpGrammar:Voice",
                    "text": "Dump grammar to log",
                    "type": "toggle",
                    "help": "When ON, writes the full live phrase-to-command grammar to SpeakUp.log once.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": true }
                },
                {
                    "id": "bRestartRecognizer:Voice",
                    "text": "Restart recognizer (toggle to restart)",
                    "type": "toggle",
                    "help": "Flip this to re-launch the speech recognizer WITHOUT restarting the game — use it if the mic was busy/disconnected/muted at launch (after you fix the mic). Closing the MCM applies it; the recognizer re-initialises and re-opens the mic.",
                    "valueOptions": { "sourceType": "ModSettingBool", "defaultValue": false }
                }
            ]
        }
    ]
}
